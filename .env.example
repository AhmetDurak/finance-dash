# PostgreSQL connection string
DATABASE_URL=postgres://localhost:5432/financedash

# Express session secret (generate a random value for production)
SESSION_SECRET=change-me-in-production

# Server port
PORT=3001

# Google OAuth2 (create at console.cloud.google.com)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Public URL of this server (used to build the OAuth callback URL)
# In production set to e.g. https://personal-dashboard.onrender.com
API_URL=http://localhost:3001

# Deutsche Bank PSD2 API (optional — for real bank connection)
DB_CLIENT_ID=
DB_CLIENT_SECRET=
DB_REDIRECT_URI=http://localhost:3001/api/bank/auth/callback
DB_API_BASE=https://simulator-api.db.com/gw
DB_FKN=
DB_PIN=
