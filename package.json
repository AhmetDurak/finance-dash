{
  "name": "finance-dash",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/api/app.ts",
    "build": "npm run build:client && tsc",
    "build:client": "cd client && npm ci --include=dev && npm run build",
    "start": "node dist/api/app.js",
    "db:migrate": "psql $DATABASE_URL -f src/db/schema.sql",
    "import:pdf": "npx tsx scripts/import-db-pdf.ts",
    "test": "jest"
  },
  "dependencies": {
    "@types/multer": "^2.1.0",
    "@types/pdf-parse": "^1.1.5",
    "axios": "^1.7.2",
    "connect-pg-simple": "^10.0.0",
    "dotenv": "^16.4.5",
    "expo": "^55.0.23",
    "express": "^4.19.2",
    "express-session": "^1.19.0",
    "multer": "^2.1.1",
    "passport": "^0.7.0",
    "passport-google-oauth20": "^2.0.0",
    "pdf-parse": "^2.4.5",
    "pg": "^8.12.0",
    "uuid": "^10.0.0",
    "yahoo-finance2": "^3.14.1"
  },
  "devDependencies": {
    "@types/connect-pg-simple": "^7.0.3",
    "@types/express": "^4.17.21",
    "@types/express-session": "^1.19.0",
    "@types/jest": "^29.5.12",
    "@types/node": "^20.14.10",
    "@types/passport": "^1.0.17",
    "@types/passport-google-oauth20": "^2.0.17",
    "@types/pg": "^8.11.6",
    "@types/react": "~19.2.10",
    "@types/uuid": "^10.0.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.5.3"
  }
}
